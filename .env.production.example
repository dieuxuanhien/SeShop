SESHOP_BACKEND_IMAGE=ghcr.io/owner/repository/seshop-backend:latest
SESHOP_FRONTEND_IMAGE=ghcr.io/owner/repository/seshop-frontend:latest

PUBLIC_ORIGIN=https://shop.example.com
HTTP_PORT=80

POSTGRES_DB=seshop
POSTGRES_USER=seshop
POSTGRES_PASSWORD=replace-with-strong-database-password

JWT_ISSUER=seshop
JWT_SECRET=replace-with-at-least-64-random-characters
JWT_EXPIRATION_MINUTES=60

STRIPE_ENABLED=false
STRIPE_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=vnd

GHN_ENABLED=false
GHN_BASE_URL=https://dev-online-gateway.ghn.vn
GHN_TOKEN=
GHN_SHOP_ID=
GHN_CREATE_ORDER_PATH=/shiip/public-api/v2/shipping-order/create
GHN_TRACK_PATH=/shiip/public-api/v2/shipping-order/detail

GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

META_ENABLED=false
META_BASE_URL=https://graph.facebook.com/v25.0
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://shop.example.com/api/v1/webhooks/instagram/callback
META_SCOPES=instagram_basic,pages_show_list,pages_read_engagement,instagram_content_publish

JAVA_OPTS=-XX:MaxRAMPercentage=75

PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

GRAFANA_IMAGE=grafana/grafana:11.3.0
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=https://shop.example.com/grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
