@startuml
actor Staff
actor "Super Admin" as Admin
participant "Backoffice UI" as UI
participant "Inventory Service" as IS
participant "Audit Service" as AS
database "SESHOP DB" as DB

Staff -> UI: Submit transfer request
UI -> IS: createTransfer(source, destination, items)
IS -> DB: validate stock and insert transfer(PENDING_APPROVAL)
DB --> IS: transferId
IS -> AS: log(action=create_transfer)
AS -> DB: insert audit_logs
IS --> UI: requestSubmitted

Admin -> UI: Open pending transfer
UI -> IS: approveTransfer(transferId)
IS -> DB: update transfer status=APPROVED
IS -> DB: deduct source on_hand_qty
IS -> DB: add destination on_hand_qty (on receipt)
IS -> AS: log(action=approve_transfer)
AS -> DB: insert audit_logs
IS --> UI: transferCompleted
UI --> Staff: Notify transfer completed
@enduml
